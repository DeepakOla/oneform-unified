{
  "name": "oneform-unified",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "description": "OneForm Unified Platform — B2B2G Middleware for India (Turborepo Monorepo)",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:start": "docker-compose up -d postgres redis",
    "db:stop": "docker-compose stop postgres redis",
    "db:migrate": "pnpm --filter @oneform/api exec prisma migrate dev",
    "db:studio": "pnpm --filter @oneform/api exec prisma studio",
    "db:seed": "pnpm --filter @oneform/api exec tsx prisma/seed.ts",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3"
  }
}
