# OneForm Unified Platform — Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to git!
#
# Date: March 2026
# Stack: Node.js 24 LTS | PostgreSQL 17 | Redis 8 | React 19

# =============================================================================
# DATABASE (PostgreSQL 17 on Hetzner / local Docker)
# =============================================================================
DATABASE_URL="postgresql://oneform:oneform_dev_secret@localhost:5432/oneform_dev?schema=public"
POSTGRES_DB="oneform_dev"
POSTGRES_USER="oneform"
POSTGRES_PASSWORD="oneform_dev_secret"

# =============================================================================
# REDIS (Redis 8 on Hetzner / local Docker)
# =============================================================================
REDIS_URL="redis://localhost:6379"
# For production with auth:
# REDIS_URL="redis://:password@redis-host:6379"

# =============================================================================
# JWT AUTHENTICATION (generate with: openssl rand -base64 64)
# =============================================================================
JWT_ACCESS_SECRET="REPLACE_WITH_64_BYTE_RANDOM_SECRET"
JWT_REFRESH_SECRET="REPLACE_WITH_DIFFERENT_64_BYTE_RANDOM_SECRET"
JWT_ACCESS_EXPIRES_IN="15m"     # Short-lived access tokens
JWT_REFRESH_EXPIRES_IN="7d"     # Long-lived refresh tokens

# =============================================================================
# ENCRYPTION (AES-256-GCM for Section A PII)
# Key Encryption Key (KEK) — 32 bytes base64 encoded
# Generate with: openssl rand -base64 32
# =============================================================================
ENCRYPTION_KEK="REPLACE_WITH_32_BYTE_BASE64_KEY_ENCRYPTION_KEY"
# In production, use HSM/KMS (AWS KMS, Google Cloud KMS, Vault)

# =============================================================================
# SERVER
# =============================================================================
NODE_ENV="development"
PORT=4000
API_URL="http://localhost:4000"
FRONTEND_URL="http://localhost:3000"
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173"

# =============================================================================
# OAUTH PROVIDERS (optional — comment out what you're not using)
# =============================================================================
# Google OAuth (for Google login)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:4000/api/auth/google/callback"

# DigiLocker OAuth (for Indian government document auto-fill)
DIGILOCKER_CLIENT_ID=""
DIGILOCKER_CLIENT_SECRET=""
DIGILOCKER_CALLBACK_URL="http://localhost:4000/api/auth/digilocker/callback"

# =============================================================================
# OTP (for Phone + OTP login) — Indian users
# Choose ONE: Twilio or MSG91 or 2Factor
# =============================================================================
OTP_PROVIDER="msg91"  # twilio | msg91 | 2factor
MSG91_AUTH_KEY=""
MSG91_TEMPLATE_ID=""
# OR
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER="+1234567890"

# =============================================================================
# CLOUDFLARE R2 (Document/Image Storage — zero egress fee)
# =============================================================================
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="oneform-documents"
R2_PUBLIC_URL="https://documents.indianform.com"

# =============================================================================
# AI SERVICES (on Hetzner — accessed via Cloudflare Tunnel)
# =============================================================================
SKYVERN_API_URL="https://beta.skyvern.com"
SKYVERN_API_KEY=""

# Qwen-VL (vision) via Ollama on Hetzner
OLLAMA_URL="http://localhost:11434"  # Change to Hetzner tunnel URL in prod
QWEN_VL_MODEL="qwen2-vl:7b"

# DeepSeek (reasoning)
DEEPSEEK_API_URL="http://localhost:11434"
DEEPSEEK_MODEL="deepseek-r1:14b"

# Surya OCR
SURYA_OCR_URL="http://localhost:8020"

# =============================================================================
# PAYMENTS (Razorpay — for guest user ₹29/form)
# =============================================================================
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
GUEST_FORM_PRICE_INR=29

# =============================================================================
# MONITORING & OBSERVABILITY
# =============================================================================
SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"  # development | staging | production

# PostHog (privacy-friendly analytics — no Google Analytics)
POSTHOG_API_KEY=""
POSTHOG_HOST="https://app.posthog.com"

# =============================================================================
# RATE LIMITING
# =============================================================================
GUEST_RATE_LIMIT_PER_HOUR=10     # Max 10 guest autofills/hour
AUTH_RATE_LIMIT_PER_MINUTE=5     # Max 5 login attempts/minute
API_RATE_LIMIT_PER_MINUTE=100    # General API rate limit

# =============================================================================
# TEMPORARY PROFILES (Guest User)
# =============================================================================
TEMP_PROFILE_EXPIRY_HOURS=8      # Guest profiles expire after 8 hours

# =============================================================================
# BRANDING (for emails, OTP messages)
# =============================================================================
APP_NAME="OneForm"
APP_DOMAIN="indianform.com"
SUPPORT_EMAIL="support@indianform.com"
SECURITY_EMAIL="security@indianform.com"
