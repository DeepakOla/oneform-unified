{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "paths": {
      "@oneform/shared-types": ["../../packages/shared-types/src"],
      "@oneform/validation": ["../../packages/validation/src"]
    }
  },
  "references": [
    { "path": "../../packages/shared-types" },
    { "path": "../../packages/validation" }
  ],
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
